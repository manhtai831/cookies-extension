{
  "{{chrome}}.manifest_version": 3,
  "{{firefox}}.manifest_version": 2,
  "name": "Cookies Manager",
  "version": "1.0.0",
  "description": "Manage cookies with API integration",
  "icons": {
    "16": "icon/cookies.png",
    "32": "icon/cookies.png",
    "48": "icon/cookies.png",
    "96": "icon/cookies.png",
    "128": "icon/cookies.png"
  },
  "{{chrome}}.action": {
    "default_popup": "src/popup.html"
  },
  "{{firefox}}.browser_action": {
    "default_popup": "src/popup.html"
  },
  "background": {
    "{{chrome}}.service_worker": "src/background.ts",
    "{{firefox}}.scripts": ["src/background.ts"]
  },
  "permissions": [
    "alarms",
    "cookies",
    "storage",
    "tabs",
    "activeTab"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ]
}
